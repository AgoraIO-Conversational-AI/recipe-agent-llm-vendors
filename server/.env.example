AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate
AGENT_GREETING=Hi! Talk to me and watch the event timeline light up.

# Select the LLM vendor for the agent's reasoning leg. Default is the keyless,
# Agora-managed `openai` vendor, so this recipe runs zero-key out of the box.
# Set LLM_VENDOR to any value below and provide that vendor's credentials to swap.
# LLM_VENDOR=openai
# LLM_MODEL=gpt-4o-mini   # optional model override for the selected vendor

# --- BYO LLM vendors (set LLM_VENDOR + the listed env vars to use one) ---

# LLM_VENDOR=anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key

# LLM_VENDOR=gemini
# GEMINI_API_KEY=your_gemini_api_key

# LLM_VENDOR=groq
# GROQ_API_KEY=your_groq_api_key

# LLM_VENDOR=azure
# AZURE_OPENAI_API_KEY=your_azure_openai_api_key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=your_deployment_name

# LLM_VENDOR=bedrock
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_REGION=us-east-1

# LLM_VENDOR=vertexai
# GOOGLE_API_KEY=your_google_access_token
# GOOGLE_PROJECT_ID=your_gcp_project_id
# GOOGLE_LOCATION=us-central1

# LLM_VENDOR=dify
# DIFY_API_KEY=your_dify_api_key
# DIFY_URL=https://api.dify.ai/v1/chat-messages

# LLM_VENDOR=custom
# CUSTOM_LLM_API_KEY=your_custom_llm_api_key
# CUSTOM_LLM_BASE_URL=https://your-openai-compatible-endpoint/v1/chat/completions
